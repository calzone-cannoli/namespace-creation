---
# Namespace Definition (mirrors create_namespace role)
apiVersion: v1
kind: Namespace
metadata:
  name: "{{ item.name }}"
  labels:
    tenant: "{{ tenant_id }}"
    environment: "{{ item.env | lower }}"
    provisioned-by: ansible-automation-platform

---
# Resource Quota Definition
apiVersion: v1
kind: ResourceQuota
metadata:
  name: resource-quota
  namespace: "{{ item.name }}"
spec:
  hard:
    # NOTE: ResourceQuotas for each size are defined in vars/main.yml
    requests.cpu: "{{ vars[cpu_req] }}"
    requests.memory: "{{ vars[mem_req] }}"
    limits.cpu: "{{ vars[cpu_lim] }}"
    limits.memory: "{{ vars[mem_lim] }}"
    pods: "{{ vars[pods] }}"
    services: "{{ vars[servs] }}"

---
apiVersion: user.openshift.io/v1
kind: Group
metadata:
  name: "openshift.{{ tenant_id }}{{ item.env | lower }}.admin.users"
users: null

---
apiVersion: user.openshift.io/v1
kind: Group
metadata:
  name: "openshift.{{ tenant_id }}{{ item.env | lower }}.login.users"
users: null

---
apiVersion: user.openshift.io/v1
kind: Group
metadata:
  name: "openshift.{{ tenant_id }}{{ item.env | lower }}.appsupport.users"
users: null

---
{% if 'dev' in item.env | lower or 'qa' in item.env | lower %}
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: admin-rb
  namespace: "{{ item.name }}"
subjects:
- kind: Group
  name: openshift.devops.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.middleware.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.dev.login.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: "openshift.{{ tenant_id }}{{ item.env | lower }}.admin.users"
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: "openshift.{{ tenant_id }}{{ item.env | lower }}.login.users"
  apiGroup: rbac.authorization.k8s.io
- kind: User
  name: system:serviceaccount:ucd-agent:ucd
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: admin
  apiGroup: rbac.authorization.k8s.io

{% elif 'stage' in item.env | lower %}
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: admin-rb
  namespace: "{{ item.name }}"
subjects:
- kind: User
  name: system:serviceaccount:ucd-agent:ucd
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.staging.admin.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: "openshift.{{ tenant_id }}stage.admin.users"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: admin
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: view-rb
  namespace: "{{ item.name }}"
subjects:
- kind: Group
  name: openshift.devops.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.middleware.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.staging.login.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: "openshift.{{ tenant_id }}stage.login.users"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: view
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: appsupport-rb
  namespace: "{{ item.name }}"
subjects:
- kind: Group
  name: "openshift.{{ tenant_id }}stage.appsupport.users"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: labcorp-app-support
  apiGroup: rbac.authorization.k8s.io

{% elif 'prod' in item.env | lower %}
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: admin-rb
  namespace: "{{ item.name }}"
subjects:
- kind: User
  name: system:serviceaccount:ucd-agent:ucd
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: "openshift.{{ tenant_id }}prod.admin.users"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: admin
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: view-rb
  namespace: "{{ item.name }}"
subjects:
- kind: Group
  name: openshift.devops.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.middleware.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: openshift.prod.login.users
  apiGroup: rbac.authorization.k8s.io
- kind: Group
  name: "openshift.{{ tenant_id }}prod.login.users"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: view
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: appsupport-rb
  namespace: "{{ item.name }}"
subjects:
- kind: Group
  name: "openshift.{{ tenant_id }}prod.appsupport.users"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: labcorp-app-support
  apiGroup: rbac.authorization.k8s.io
{% endif %}